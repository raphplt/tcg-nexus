{
  "extends": "@repo/typescript-config/expo.json",
  "compilerOptions": {
    "strict": true,
    "skipLibCheck": true,
    // Metro gère le bundling : tsc ne doit rien émettre dans app/
    "noEmit": true,
    "declaration": false,
    "declarationMap": false,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "react-native-env.d.ts"]
}
