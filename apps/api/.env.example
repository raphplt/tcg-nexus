# Database Configuration
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=your_db_user
DATABASE_PASSWORD=your_db_password
DATABASE_NAME=tcg_nexus

# JWT Configuration
JWT_SECRET=your-very-secret-jwt-key-here-make-it-long-and-random
JWT_REFRESH_SECRET=your-even-more-secret-refresh-key-here-also-long-and-random
# Durée de vie du access token (formats: 15m, 1h, 7d, ou nombre brut en secondes)
JWT_EXPIRES_IN=15m
# Durée de vie du refresh token (sliding, doit être bien plus long que JWT_EXPIRES_IN)
JWT_REFRESH_EXPIRES_IN=30d

# App Configuration
PORT=3001
NODE_ENV=development

# Scan / OCR Configuration
OCR_LANGS=eng+fra
# moteur OCR : tesseract (défaut) ou vision
OCR_ENGINE=tesseract
# clé Google Vision, requise seulement si OCR_ENGINE=vision
GOOGLE_VISION_API_KEY=
# dossier local des traineddata (offline). vide => téléchargement CDN
# OCR_LANG_PATH=/app/tessdata
VISION_SERVICE_URL=http://localhost:8000

R2_PUBLIC_URL=https://cdn.tcg-nexus.org

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# SMTP Configuration (email notifications)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM="TCG Nexus" <noreply@tcg-nexus.org>

