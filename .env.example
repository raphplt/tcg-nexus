# Copiez ce fichier vers .env et ajustez les valeurs

# ================================
# Base de données PostgreSQL
# ================================
# Ces valeurs doivent correspondre à celles du docker-compose.yml
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=tcg_nexus
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres

# ================================
# Mobile OCR (Google Cloud Vision API)
# ================================
# Clé API Google Vision pour le scan de cartes
EXPO_PUBLIC_VISION_API_KEY=votre_cle_api_ici

